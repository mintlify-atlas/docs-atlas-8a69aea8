  "keyFeatures": [
    "Order and delivery management with visual Kanban boards",
    "Real-time fleet tracking and driver management",
    "Service zone configuration and route optimization",
    "Extensible plugin architecture with marketplace",
    "RESTful API with webhooks and socket support",
    "Multi-tenant IAM with dynamic permissions",
    "Mobile apps for drivers and customers",
    "Docker-based deployment with cloud and on-premise options"
  ],
  "publicApiSurface": [
    "POST /orders - Create delivery orders",
    "GET /orders/:id - Retrieve order details",
    "GET /orders/:id/tracking - Track order in real-time",
    "POST /drivers - Create driver profiles",
    "GET /fleet/live - Get live fleet positions",
    "POST /service-areas - Define service zones",
    "POST /routes/optimize - Optimize delivery routes",
    "GET /tracking/:id - Public tracking endpoint",
    "POST /webhooks - Register webhook endpoints",
    "flb install-fleetbase - Install Fleetbase via CLI",
    "flb install <extension> - Install extensions",
    "flb scaffold - Create new extension",
    "flb publish - Publish extension to registry"
  ]
